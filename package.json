{
  "name": "winplate",
  "productName": "WinPlate",
  "version": "0.1.0",
  "private": true,
  "description": "WinPlate monorepo workspace orchestrator.",
  "workspaces": [
    "apps/windows-electron",
    "apps/macos/electron-menubar",
    "packages/core",
    "packages/shared-types",
    "packages/icons"
  ],
  "scripts": {
    "start": "npm run start --workspace @winplate/windows-electron",
    "dev": "npm run dev --workspace @winplate/windows-electron",
    "electron": "npm run electron --workspace @winplate/windows-electron",
    "backend": "uvicorn backend.main:api --host 127.0.0.1 --port 8765 --reload --use-colors --log-config backend/logging.json",
    "frontend": "echo Frontend ready",
    "precheck": "npm run precheck --workspace @winplate/windows-electron",
    "check": "npm run check --workspace @winplate/windows-electron && npm run test:layout && npm test --workspace @winplate/macos-electron-menubar --workspace @winplate/core --workspace @winplate/shared-types --workspace @winplate/icons",
    "test:layout": "node --test scripts/workspaceLayout.test.js",
    "check:syntax": "npm run check:syntax --workspace @winplate/windows-electron && node --check scripts/venvPython.js",
    "test:unit": "node --test scripts/venvPython.test.js && npm run test:unit --workspace @winplate/windows-electron",
    "venv:create": "python -m venv .venv",
    "backend:install": "node scripts/venvPython.js -m pip install -r backend/requirements.txt",
    "backend:test": "node scripts/venvPython.js -m unittest discover -s backend -p \"test_*.py\""
  }
}
